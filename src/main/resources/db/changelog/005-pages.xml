<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-pages-table" author="ProuDig">
        <createTable tableName="pages">
            <column name="id" type="VARCHAR(36)" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT"/>
            <column name="excerpt" type="VARCHAR(500)"/>
            <column name="cover_image_id" type="VARCHAR(36)"/>
            <column name="tags" type="VARCHAR(1000)"/>
            <column name="meta_data" type="TEXT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="author_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="published_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="pages" baseColumnNames="cover_image_id"
                                 referencedTableName="media" referencedColumnNames="id"
                                 constraintName="fk_pages_cover_image_id"/>
        <addForeignKeyConstraint baseTableName="pages" baseColumnNames="author_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_pages_author_id"/>
    </changeSet>

</databaseChangeLog>
