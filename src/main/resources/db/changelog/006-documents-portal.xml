<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-folders-table" author="ProuDig">
        <createTable tableName="folders">
            <column name="id" type="VARCHAR(36)" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_folder_id" type="VARCHAR(36)"/>
            <column name="owner_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="folders" baseColumnNames="parent_folder_id"
                                 referencedTableName="folders" referencedColumnNames="id"
                                 constraintName="fk_folders_parent_folder_id"/>
        <addForeignKeyConstraint baseTableName="folders" baseColumnNames="owner_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_folders_owner_id"/>
    </changeSet>

    <changeSet id="002-create-documents-table" author="ProuDig">
        <createTable tableName="documents">
            <column name="id" type="VARCHAR(36)" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="storage_path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="content_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="folder_id" type="VARCHAR(36)"/>
            <column name="uploaded_by" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="documents" baseColumnNames="folder_id"
                                 referencedTableName="folders" referencedColumnNames="id"
                                 constraintName="fk_documents_folder_id"/>
        <addForeignKeyConstraint baseTableName="documents" baseColumnNames="uploaded_by"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_documents_uploaded_by"/>
    </changeSet>

    <changeSet id="003-create-document-shares-table" author="ProuDig">
        <createTable tableName="document_shares">
            <column name="id" type="VARCHAR(36)" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="shared_with" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="shared_by" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="permission" type="VARCHAR(20)" defaultValue="VIEW">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="document_shares" baseColumnNames="document_id"
                                 referencedTableName="documents" referencedColumnNames="id"
                                 constraintName="fk_document_shares_document_id"/>
        <addForeignKeyConstraint baseTableName="document_shares" baseColumnNames="shared_with"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_document_shares_shared_with"/>
        <addForeignKeyConstraint baseTableName="document_shares" baseColumnNames="shared_by"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_document_shares_shared_by"/>
    </changeSet>

</databaseChangeLog>
