<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-activity-log-table" author="ProuDig">
        <createTable tableName="activity_log">
            <column name="id" type="VARCHAR(36)" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="VARCHAR(255)"/>
            <column name="details" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="activity_log" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_activity_log_user_id"/>
        <createIndex indexName="idx_activity_log_user_id" tableName="activity_log">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_activity_log_entity_type" tableName="activity_log">
            <column name="entity_type"/>
        </createIndex>
        <createIndex indexName="idx_activity_log_created_at" tableName="activity_log">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
