<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Generische, über die Admin-UI konfigurierbare Systemeinstellungen (Key-Value) -->
    <changeSet id="015-create-settings" author="ProuDig">
        <createTable tableName="settings">
            <column name="setting_key" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="setting_value" type="VARCHAR(500)"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="updated_by" type="VARCHAR(36)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
