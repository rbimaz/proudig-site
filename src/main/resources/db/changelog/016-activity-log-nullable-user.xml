<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- System-/Auto-Events (z. B. automatische News-Archivierung) haben keinen auslösenden Nutzer -->
    <changeSet id="016-activity-log-nullable-user" author="ProuDig">
        <dropNotNullConstraint tableName="activity_log" columnName="user_id" columnDataType="VARCHAR(36)"/>
    </changeSet>

</databaseChangeLog>
